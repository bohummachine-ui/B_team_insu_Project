# ============================================================
# 백지운 지점 팀 CRM — 환경 변수 템플릿
# 이 파일을 복사해서 .env.local 을 만들고 실제 값을 채우세요.
# .env.local 은 절대 git에 커밋하지 마세요!
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Supabase 프로젝트 대시보드 > Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 서버 전용 (절대 클라이언트에 노출 금지!) — RLS 우회, 어드민 작업용
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Google OAuth / Drive API ─────────────────────────────────
# Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── 앱 설정 ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 단일 팀 ID (Supabase teams 테이블의 row ID — 배포 후 확인)
NEXT_PUBLIC_OFFICE_TEAM_ID=00000000-0000-0000-0000-000000000000

# ── 보안 ────────────────────────────────────────────────────
# google_refresh_token 암호화용 32바이트 hex 키
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
